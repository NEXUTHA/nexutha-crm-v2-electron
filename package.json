{
  "name": "nexutha-crm",
  "version": "2.1.0",
  "description": "NEXUTHA CRM - 完全ローカル型顧客管理システム",
  "main": "main.js",
  "author": "Yamashita Yasuhide / NEXUTHA",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "net.nexutha.crm",
    "productName": "NEXUTHA CRM",
    "copyright": "© 2026 Yamashita Yasuhide / NEXUTHA",
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend"
      },
      {
        "from": "index.html",
        "to": "index.html"
      },
      {
        "from": "style.css",
        "to": "style.css"
      },
      {
        "from": "js",
        "to": "js"
      },
      {
        "from": "manifest.json",
        "to": "manifest.json"
      },
      {
        "from": "sw.js",
        "to": "sw.js"
      },
      {
        "from": "favicon.ico",
        "to": "favicon.ico"
      },
      {
        "from": "version.json",
        "to": "version.json"
      }
    ],
    "files": [
      "main.js",
      "preload.js"
    ]
  }
}