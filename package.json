{
  "name": "nexutha-crm",
  "version": "2.3.3",
  "description": "NEXUTHA CRM - 完全ローカル型顧客管理システム",
  "main": "main.js",
  "author": "Yamashita Yasuhide / NEXUTHA",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "bash check-before-build.sh && electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.59.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "net.nexutha.crm",
    "productName": "NEXUTHA CRM",
    "copyright": "© 2026 Yamashita Yasuhide / NEXUTHA",
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": "Yasuhide Yamashita (5ZW26ADG2F)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend"
      },
      {
        "from": "index.html",
        "to": "index.html"
      },
      {
        "from": "style.css",
        "to": "style.css"
      },
      {
        "from": "js",
        "to": "js"
      },
      {
        "from": "manifest.json",
        "to": "manifest.json"
      },
      {
        "from": "sw.js",
        "to": "sw.js"
      },
      {
        "from": "favicon.ico",
        "to": "favicon.ico"
      },
      {
        "from": "version.json",
        "to": "version.json"
      }
    ],
    "files": [
      "main.js",
      "preload.js"
    ],
    "publish": {
      "provider": "github",
      "owner": "NEXUTHA",
      "repo": "nexutha-crm-v2-electron"
    },
    "afterSign": "scripts/notarize.js"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "electron-updater": "^6.8.3"
  }
}